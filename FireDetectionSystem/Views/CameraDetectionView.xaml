<UserControl
    x:Class="FireDetectionSystem.Views.CameraDetectionView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:FireDetectionSystem.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  左侧：摄像头列表  -->
        <Border
            Background="#16191f"
            BorderBrush="#2a2f3e"
            BorderThickness="1"
            CornerRadius="10"
            Margin="5"
            Padding="12">
            <StackPanel>
                <TextBlock
                    FontSize="18"
                    FontWeight="SemiBold"
                    Foreground="White"
                    Text="摄像头列表" />
                <TextBlock Foreground="#B8C5D6" Margin="0,6,0,8">
                    <Run Text="已连接: " />
                    <Run Text="{Binding ConnectedCount, Mode=OneWay}" />
                    <Run Text="  运行中: " />
                    <Run Text="{Binding RunningCount, Mode=OneWay}" />
                </TextBlock>

                <StackPanel Orientation="Horizontal">
                    <Button
                        Command="{Binding AddVideoSourceCommand}"
                        Content="添加视频源"
                        Margin="0,0,8,0"
                        Width="120" />
                    <Button
                        Command="{Binding RemoveSelectedCommand}"
                        Content="移除"
                        Width="70" />
                </StackPanel>

                <ListBox
                    Background="Transparent"
                    BorderThickness="0"
                    ItemsSource="{Binding Cameras}"
                    Margin="0,10,0,0"
                    SelectedItem="{Binding SelectedCamera}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Background="#1f2431"
                                BorderBrush="#2a2f3e"
                                BorderThickness="1"
                                CornerRadius="8"
                                Margin="0,0,0,8"
                                Padding="8">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Foreground="White"
                                        Text="{Binding Name}" />
                                    <TextBlock
                                        Foreground="#B8C5D6"
                                        Grid.Row="1"
                                        Text="{Binding StatusText}" />
                                    <TextBlock
                                        FontSize="12"
                                        Foreground="#B8C5D6"
                                        Grid.Row="2"
                                        Text="{Binding AlertMessage}" />
                                </Grid>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsAlert}" Value="True">
                                                <Setter Property="BorderBrush" Value="#FF5C5C" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Border>

        <!--  右侧：状态与检测结果  -->
        <Grid Grid.Column="1" Margin="5,5,5,5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="130" />
                <RowDefinition Height="200" />
            </Grid.RowDefinitions>

            <!--  顶部控制区  -->
            <StackPanel Orientation="Horizontal">
                <TextBlock
                    Foreground="White"
                    Margin="0,0,6,0"
                    Text="置信度阈值"
                    VerticalAlignment="Center" />
                <Slider
                    IsSnapToTickEnabled="True"
                    Maximum="1"
                    Minimum="0"
                    TickFrequency="0.1"
                    Value="{Binding ConfidenceThreshold, Mode=TwoWay}"
                    Width="160" />
                <TextBlock
                    Foreground="White"
                    Margin="6,0,20,0"
                    Text="{Binding ConfidenceThreshold, StringFormat={}{0:P0}}"
                    VerticalAlignment="Center" />

                <TextBlock
                    Foreground="White"
                    Margin="0,0,6,0"
                    Text="预警阈值"
                    VerticalAlignment="Center" />
                <Slider
                    IsSnapToTickEnabled="True"
                    Maximum="1"
                    Minimum="0"
                    TickFrequency="0.1"
                    Value="{Binding AlertThreshold, Mode=TwoWay}"
                    Width="160" />
                <TextBlock
                    Foreground="White"
                    Margin="6,0,20,0"
                    Text="{Binding AlertThreshold, StringFormat={}{0:P0}}"
                    VerticalAlignment="Center" />

                <Button
                    Command="{Binding StartSelectedCommand}"
                    Content="启动"
                    Margin="0,0,8,0"
                    Width="80" />
                <Button
                    Command="{Binding ToggleSelectedPauseCommand}"
                    Content="{Binding SelectedCamera.PauseButtonText, FallbackValue=暂停}"
                    Width="80" />
            </StackPanel>

            <!--  状态与预警  -->
            <Grid Grid.Row="1" Margin="0,10,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="240" />
                </Grid.ColumnDefinitions>
                <Border
                    Background="#16191f"
                    BorderBrush="#2a2f3e"
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="0,0,10,0"
                    Padding="10">
                    <Grid DataContext="{Binding SelectedCamera}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock
                            FontSize="16"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Text="摄像头状态" />
                        <TextBlock Foreground="#B8C5D6" Grid.Row="1">
                            <Run Text="名称: " />
                            <Run Text="{Binding Name}" />
                            <Run Text="   状态: " />
                            <Run Text="{Binding StatusText}" />
                        </TextBlock>
                        <TextBlock Foreground="#B8C5D6" Grid.Row="2">
                            <Run Text="源: " />
                            <Run Text="{Binding SourcePath}" />
                        </TextBlock>
                    </Grid>
                </Border>
                <Border
                    Background="#1f2431"
                    BorderBrush="#2a2f3e"
                    BorderThickness="1"
                    CornerRadius="8"
                    DataContext="{Binding SelectedCamera}"
                    Grid.Column="1"
                    Padding="10">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsAlert}" Value="True">
                                    <Setter Property="Background" Value="#3a1f1f" />
                                    <Setter Property="BorderBrush" Value="#FF5C5C" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock
                            FontSize="16"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Text="预警信息" />
                        <TextBlock
                            Foreground="#B8C5D6"
                            Margin="0,6,0,0"
                            Text="{Binding AlertMessage}" />
                    </StackPanel>
                </Border>
            </Grid>

            <!--  画面显示  -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Border
                    Background="#16191f"
                    BorderBrush="#2a2f3e"
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="0,0,10,0"
                    Padding="8">
                    <Image Source="{Binding SelectedCamera.OriginalFrame}" Stretch="Uniform" />
                </Border>
                <Border
                    Background="#16191f"
                    BorderBrush="#2a2f3e"
                    BorderThickness="1"
                    CornerRadius="8"
                    Grid.Column="1"
                    Padding="8">
                    <Image Source="{Binding SelectedCamera.DetectionFrame}" Stretch="Uniform" />
                </Border>
            </Grid>

            <!--  实时检测列表  -->
            <Grid Grid.Row="3" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="220" />
                </Grid.ColumnDefinitions>
                <Border
                    Background="#16191f"
                    BorderBrush="#2a2f3e"
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="0,0,10,0"
                    Padding="10">
                    <ListView
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="White"
                        ItemsSource="{Binding SelectedCamera.DetectionInfos}">
                        <ListView.Resources>
                            <Style TargetType="GridViewColumnHeader">
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="Background" Value="#2a2f3e" />
                                <Setter Property="Padding" Value="6,4" />
                                <Setter Property="BorderBrush" Value="#2a2f3e" />
                                <Setter Property="BorderThickness" Value="0,0,0,1" />
                            </Style>
                        </ListView.Resources>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn
                                    DisplayMemberBinding="{Binding Label}"
                                    Header="目标"
                                    Width="140" />
                                <GridViewColumn
                                    DisplayMemberBinding="{Binding Confidence, StringFormat={}{0:P1}}"
                                    Header="置信度"
                                    Width="100" />
                                <GridViewColumn
                                    DisplayMemberBinding="{Binding Box}"
                                    Header="位置"
                                    Width="200" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Border>
                <Border
                    Background="#16191f"
                    BorderBrush="#2a2f3e"
                    BorderThickness="1"
                    CornerRadius="8"
                    DataContext="{Binding SelectedCamera}"
                    Grid.Column="1"
                    Padding="10">
                    <StackPanel>
                        <TextBlock
                            FontSize="16"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Text="检测摘要" />
                        <TextBlock Foreground="#B8C5D6">
                            <Run Text="检测数量: " />
                            <Run Text="{Binding DetectionCount}" />
                        </TextBlock>
                        <TextBlock Foreground="#B8C5D6">
                            <Run Text="最高置信度: " />
                            <Run Text="{Binding MaxConfidence, StringFormat={}{0:P1}}" />
                        </TextBlock>
                        <TextBlock Foreground="#B8C5D6">
                            <Run Text="更新时间: " />
                            <Run Text="{Binding LastUpdateTime}" />
                        </TextBlock>
                        <TextBlock Foreground="#B8C5D6">
                            <Run Text="推理耗时: " />
                            <Run Text="{Binding InferenceTimeMs, StringFormat={}{0:F0}}" />
                            <Run Text=" ms" />
                        </TextBlock>
                        <TextBlock Foreground="#B8C5D6">
                            <Run Text="检测帧率: " />
                            <Run Text="{Binding DetectionFps, StringFormat={}{0:F1}}" />
                            <Run Text=" FPS" />
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>

            <!--  报警处置区域  -->
            <Border
                Background="#16191f"
                BorderBrush="#2a2f3e"
                BorderThickness="1"
                CornerRadius="8"
                Grid.Row="4"
                Margin="0,8,0,0"
                Padding="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="250" />
                    </Grid.ColumnDefinitions>

                    <!--  待处置报警列表  -->
                    <DockPanel>
                        <DockPanel
                            DockPanel.Dock="Top"
                            LastChildFill="False"
                            Margin="0,0,0,6">
                            <TextBlock
                                FontSize="14"
                                FontWeight="SemiBold"
                                Foreground="White"
                                Text="待处置报警"
                                VerticalAlignment="Center" />
                            <Button
                                Command="{Binding RefreshPendingAlarmsCommand}"
                                Content="刷新"
                                DockPanel.Dock="Right"
                                Width="60" />
                        </DockPanel>
                        <ListView
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="White"
                            ItemsSource="{Binding PendingAlarms}"
                            SelectedItem="{Binding SelectedAlarm}">
                            <ListView.Resources>
                                <Style TargetType="GridViewColumnHeader">
                                    <Setter Property="Foreground" Value="White" />
                                    <Setter Property="Background" Value="#2a2f3e" />
                                    <Setter Property="Padding" Value="6,4" />
                                    <Setter Property="BorderBrush" Value="#2a2f3e" />
                                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                                </Style>
                            </ListView.Resources>
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn
                                        DisplayMemberBinding="{Binding DetectionTime, StringFormat={}{0:MM-dd HH:mm:ss}}"
                                        Header="检测时间"
                                        Width="150" />
                                    <GridViewColumn
                                        DisplayMemberBinding="{Binding SourcePath}"
                                        Header="来源摄像头"
                                        Width="130" />
                                    <GridViewColumn
                                        DisplayMemberBinding="{Binding MaxConfidence, StringFormat={}{0:P1}}"
                                        Header="峰值置信度"
                                        Width="80" />
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </DockPanel>

                    <!--  处置操作表单  -->
                    <Border
                        Background="#1f2431"
                        BorderBrush="#2a2f3e"
                        BorderThickness="1"
                        CornerRadius="6"
                        Grid.Column="1"
                        Margin="10,0,0,0"
                        Padding="10">
                        <ScrollViewer>
                            <StackPanel>
                                <TextBlock
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Foreground="White"
                                    Margin="0,0,0,8"
                                    Text="处置选中报警" />

                                <TextBlock
                                    Foreground="#B8C5D6"
                                    Margin="0,0,0,4"
                                    Text="处置结果:" />
                                <ComboBox
                                    ItemsSource="{Binding HandleStatusOptions}"
                                    Margin="0,0,0,8"
                                    SelectedItem="{Binding SelectedHandleStatus}" />

                                <TextBlock
                                    Foreground="#B8C5D6"
                                    Margin="0,0,0,4"
                                    Text="处置备注:" />
                                <TextBox
                                    AcceptsReturn="True"
                                    Height="40"
                                    Margin="0,0,0,10"
                                    Text="{Binding HandleNotes, UpdateSourceTrigger=PropertyChanged}"
                                    TextWrapping="Wrap"
                                    VerticalScrollBarVisibility="Auto" />

                                <!--  IsEnabled 由 ConfirmHandleCommand.CanExecute 自动控制（SelectedAlarm 不为空时启用）  -->
                                <Button Command="{Binding ConfirmHandleCommand}" Content="确认处置" />
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>

        </Grid>
    </Grid>
</UserControl>
