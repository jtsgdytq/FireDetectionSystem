<UserControl
    FontFamily="Arial"
    FontSize="20"
    Height="645"
    Width="875"
    mc:Ignorable="d"
    prism:Dialog.WindowStyle="{StaticResource LoginStyle}"
    x:Class="FireDetectionSystem.Views.LoginView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:FireDetectionSystem.Views"
    xmlns:material="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:vm="clr-namespace:FireDetectionSystem.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.Effect>
            <DropShadowEffect
                BlurRadius="30"
                Opacity="0.4"
                ShadowDepth="1" />
        </Grid.Effect>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="1.22*" />
        </Grid.ColumnDefinitions>

        <!--  Left Section  -->
        <Grid>
            <Border
                Background="#FF6B35"
                ClipToBounds="True"
                CornerRadius="10 0 0 10">
                <Border.Clip>
                    <RectangleGeometry
                        RadiusX="10"
                        RadiusY="10"
                        Rect="0,0,400,605" />
                </Border.Clip>

                <Grid>
                    <!--  Titiles  -->
                    <StackPanel Margin="0,120,0,0" VerticalAlignment="Top">
                        <TextBlock
                            FontSize="46"
                            FontWeight="Light"
                            Foreground="#FFFFFF"
                            HorizontalAlignment="Center"
                            Text="欢迎" />
                        <TextBlock
                            FontSize="16"
                            FontWeight="Light"
                            Foreground="White"
                            Margin="0,15,0,3"
                            Text="使用火灾检测"
                            TextAlignment="Center" />
                        <TextBlock
                            FontSize="16"
                            FontWeight="Light"
                            Foreground="#FFFFFF"
                            HorizontalAlignment="Center"
                            Text="报警系统" />
                    </StackPanel>

                    <!--  Ellipses  -->
                    <Ellipse
                        Fill="#F7931E"
                        Height="500"
                        Margin="50,0,0,-200"
                        Opacity="0.6"
                        VerticalAlignment="Bottom"
                        Width="500" />
                    <Ellipse
                        Fill="#F7931E"
                        Height="300"
                        Margin="-450,0,0,30"
                        Opacity="0.3"
                        VerticalAlignment="Bottom"
                        Width="300" />
                    <Ellipse
                        Fill="#F7931E"
                        Height="400"
                        Margin="-320,0,0,-120"
                        Opacity="0.3"
                        VerticalAlignment="Bottom"
                        Width="400" />
                    <Ellipse
                        Fill="#F7931E"
                        Height="500"
                        Margin="50,0,0,-200"
                        Opacity="0.6"
                        VerticalAlignment="Bottom"
                        Width="500" />
                    <Ellipse
                        Fill="#F7931E"
                        Height="250"
                        Margin="-380,0,0,-120"
                        Opacity="0.6"
                        VerticalAlignment="Bottom"
                        Width="250" />
                    <Ellipse
                        Fill="#F7931E"
                        Height="400"
                        Margin="280,0,0,-70"
                        Opacity="0.8"
                        VerticalAlignment="Bottom"
                        Width="400" />

                    <!--  Icon  -->
                    <Border
                        Background="#fdfdfd"
                        CornerRadius="100"
                        Height="110"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,80"
                        VerticalAlignment="Bottom"
                        Width="110">
                        <Grid>
                            <!--  Colored Ellipses  -->
                            <Ellipse
                                Height="100"
                                StrokeThickness="4"
                                Width="100">
                                <Ellipse.Stroke>
                                    <LinearGradientBrush>
                                        <GradientStop Color="#e27c53" Offset="0.15" />
                                        <GradientStop Color="#dca503" Offset="0.2" />
                                        <GradientStop Color="#8bb356" Offset="0.3" />
                                        <GradientStop Color="#3bb799" Offset="0.4" />
                                        <GradientStop Color="#67cbee" Offset="0.5" />
                                        <GradientStop Color="#3699bd" Offset="0.6" />
                                        <GradientStop Color="#9264aa" Offset="0.8" />
                                        <GradientStop Color="#6e94de" Offset="0.9" />
                                    </LinearGradientBrush>
                                </Ellipse.Stroke>
                            </Ellipse>

                            <!--  Colored Tick Icon  -->

                            <material:PackIcon
                                Height="70"
                                HorizontalAlignment="Center"
                                Kind="Tick"
                                VerticalAlignment="Center"
                                Width="70">
                                <material:PackIcon.Foreground>
                                    <LinearGradientBrush StartPoint="0,1">
                                        <GradientStop Color="#e27c53" Offset="0.1" />
                                        <GradientStop Color="#8bb356" Offset="0.3" />
                                        <GradientStop Color="#67cbee" Offset="0.5" />
                                        <GradientStop Color="#9264aa" Offset="0.8" />
                                    </LinearGradientBrush>
                                </material:PackIcon.Foreground>
                            </material:PackIcon>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!--  Right Section  -->
        <Grid Grid.Column="1">
            <Border Background="White" CornerRadius="0 10 10 0" />
            <Grid>
                <!--  Close Icon  -->

                <Button
                    Command="{Binding CloseCommand}"
                    HorizontalAlignment="Right"
                    Margin="0,5,5,0"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    VerticalAlignment="Top">
                    <material:PackIcon
                        Height="30"
                        HorizontalAlignment="Right"
                        Kind="Close"
                        Opacity="0.3"
                        VerticalAlignment="Top"
                        Width="30" />
                </Button>

                <!--  Inputs  -->
                <StackPanel
                    Cursor="Arrow"
                    Margin="75,0"
                    VerticalAlignment="Center">
                    <TextBox
                        BorderBrush="#c5c8cc"
                        Margin="0,0,0,30"
                        Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                        Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                        material:HintAssist.FloatingOffset="0,-20"
                        material:HintAssist.Hint="用户名" />

                    <PasswordBox
                        BorderBrush="#c5c8cc"
                        Margin="0,0,0,30"
                        Style="{StaticResource MaterialDesignFloatingHintPasswordBox}"
                        material:HintAssist.FloatingOffset="0,-18"
                        material:HintAssist.Hint="密码"
                        material:PasswordBoxAssist.Password="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                        x:Name="PasswordBox" />

                    <!--  错误提示  -->
                    <Border
                        Background="#FFEBEE"
                        CornerRadius="5"
                        Margin="0,0,0,20"
                        Padding="10"
                        Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock
                            FontSize="14"
                            Foreground="#C62828"
                            Text="{Binding ErrorMessage}"
                            TextWrapping="Wrap" />
                    </Border>

                    <Button
                        Background="#dca503"
                        Command="{Binding LoginCommand}"
                        Content="登录"
                        FontSize="18"
                        Foreground="White"
                        Height="45"
                        IsEnabled="{Binding LoginCommand.CanExecute}"
                        Margin="0,20,0,0"
                        Width="200"
                        material:ButtonAssist.CornerRadius="22" />
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
