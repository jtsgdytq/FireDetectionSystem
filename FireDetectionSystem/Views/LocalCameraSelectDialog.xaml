<Window
    x:Class="FireDetectionSystem.Views.LocalCameraSelectDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#16191f"
    Height="260"
    ResizeMode="NoResize"
    Title="选择本地摄像头"
    Width="360"
    WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  提示文字  -->
        <TextBlock
            Foreground="#B8C5D6"
            Margin="0,0,0,10"
            Text="请选择要连接的本地摄像头设备：" />

        <!--  设备列表  -->
        <ListBox
            x:Name="DeviceListBox"
            Background="#1f2431"
            BorderBrush="#2a2f3e"
            BorderThickness="1"
            Foreground="White"
            Grid.Row="1"
            Padding="4">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="8,6" />
                    <Setter Property="Foreground" Value="White" />
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#2a5a9f" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#253450" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <!--  操作按钮  -->
        <StackPanel
            Grid.Row="2"
            HorizontalAlignment="Right"
            Margin="0,12,0,0"
            Orientation="Horizontal">
            <Button
                Click="OnCancel"
                Content="取消"
                Margin="0,0,8,0"
                Width="80" />
            <Button
                Click="OnConfirm"
                Content="确认连接"
                Width="90" />
        </StackPanel>
    </Grid>
</Window>
