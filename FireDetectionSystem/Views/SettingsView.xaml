<UserControl
    Background="{DynamicResource MaterialDesignPaper}"
    prism:ViewModelLocator.AutoWireViewModel="True"
    x:Class="FireDetectionSystem.Views.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16" MaxWidth="900">

            <!--  标题  -->
            <TextBlock
                Margin="0,0,0,16"
                Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                Text="系统设置" />

            <!--  ===== Card 1：模型设置 =====  -->
            <materialDesign:Card Margin="0,0,0,12" Padding="20">
                <StackPanel>
                    <StackPanel Margin="0,0,0,16" Orientation="Horizontal">
                        <materialDesign:PackIcon
                            Foreground="{DynamicResource PrimaryHueMidBrush}"
                            Kind="Robot"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center" />
                        <TextBlock
                            Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                            Text="模型设置"
                            VerticalAlignment="Center" />
                    </StackPanel>

                    <!--  模型路径  -->
                    <TextBlock
                        Foreground="{DynamicResource MaterialDesignBodyLight}"
                        Margin="0,0,0,4"
                        Style="{StaticResource MaterialDesignCaptionTextBlock}"
                        Text="ONNX 模型文件" />
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox
                            Grid.Column="0"
                            IsReadOnly="True"
                            Margin="0,0,8,0"
                            Style="{StaticResource MaterialDesignOutlinedTextBox}"
                            Text="{Binding ModelPath, UpdateSourceTrigger=PropertyChanged}"
                            materialDesign:HintAssist.Hint="模型文件路径 (.onnx)" />
                        <Button
                            Command="{Binding BrowseModelFileCommand}"
                            Grid.Column="1"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon
                                    Kind="FolderOpen"
                                    Margin="0,0,4,0"
                                    VerticalAlignment="Center" />
                                <TextBlock Text="浏览" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!--  置信度阈值  -->
                    <TextBlock
                        Foreground="{DynamicResource MaterialDesignBodyLight}"
                        Margin="0,0,0,4"
                        Style="{StaticResource MaterialDesignCaptionTextBlock}"
                        Text="置信度阈值" />
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="64" />
                        </Grid.ColumnDefinitions>
                        <Slider
                            Grid.Column="0"
                            IsSnapToTickEnabled="True"
                            Margin="0,0,12,0"
                            Maximum="0.9"
                            Minimum="0.1"
                            Style="{StaticResource MaterialDesignSlider}"
                            TickFrequency="0.05"
                            Value="{Binding ConfidenceThreshold, Mode=TwoWay}"
                            VerticalAlignment="Center" />
                        <Border
                            Background="{DynamicResource PrimaryHueLightBrush}"
                            CornerRadius="4"
                            Grid.Column="1"
                            Padding="6,4">
                            <TextBlock
                                FontWeight="Bold"
                                Foreground="{DynamicResource PrimaryHueLightForegroundBrush}"
                                HorizontalAlignment="Center"
                                Text="{Binding ConfidenceDisplay}"
                                VerticalAlignment="Center" />
                        </Border>
                    </Grid>

                    <!--  报警触发阈值  -->
                    <TextBlock
                        Foreground="{DynamicResource MaterialDesignBodyLight}"
                        Margin="0,0,0,4"
                        Style="{StaticResource MaterialDesignCaptionTextBlock}"
                        Text="报警触发阈值（置信度超过此值时触发报警）" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="64" />
                        </Grid.ColumnDefinitions>
                        <Slider
                            Grid.Column="0"
                            IsSnapToTickEnabled="True"
                            Margin="0,0,12,0"
                            Maximum="0.9"
                            Minimum="0.1"
                            Style="{StaticResource MaterialDesignSlider}"
                            TickFrequency="0.05"
                            Value="{Binding AlertThreshold, Mode=TwoWay}"
                            VerticalAlignment="Center" />
                        <Border
                            Background="{DynamicResource SecondaryHueMidBrush}"
                            CornerRadius="4"
                            Grid.Column="1"
                            Padding="6,4">
                            <TextBlock
                                FontWeight="Bold"
                                Foreground="{DynamicResource SecondaryHueMidForegroundBrush}"
                                HorizontalAlignment="Center"
                                Text="{Binding AlertThresholdDisplay}"
                                VerticalAlignment="Center" />
                        </Border>
                    </Grid>
                </StackPanel>
            </materialDesign:Card>

            <!--  ===== Card 2：报警开关 =====  -->
            <materialDesign:Card Margin="0,0,0,12" Padding="20">
                <StackPanel>
                    <StackPanel Margin="0,0,0,16" Orientation="Horizontal">
                        <materialDesign:PackIcon
                            Foreground="{DynamicResource PrimaryHueMidBrush}"
                            Kind="Bell"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center" />
                        <TextBlock
                            Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                            Text="报警通知"
                            VerticalAlignment="Center" />
                    </StackPanel>

                    <!--  声音报警  -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ToggleButton
                            Grid.Column="0"
                            IsChecked="{Binding EnableSound}"
                            Style="{StaticResource MaterialDesignSwitchToggleButton}"
                            VerticalAlignment="Center" />
                        <materialDesign:PackIcon
                            Foreground="{DynamicResource MaterialDesignBodyLight}"
                            Grid.Column="1"
                            Kind="VolumeHigh"
                            Margin="12,0,8,0"
                            VerticalAlignment="Center" />
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="声音报警" />
                            <TextBlock
                                Foreground="{DynamicResource MaterialDesignBodyLight}"
                                Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                Text="检测到火灾时播放声音提示" />
                        </StackPanel>
                    </Grid>

                    <!--  桌面通知  -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ToggleButton
                            Grid.Column="0"
                            IsChecked="{Binding EnableDesktopNotification}"
                            Style="{StaticResource MaterialDesignSwitchToggleButton}"
                            VerticalAlignment="Center" />
                        <materialDesign:PackIcon
                            Foreground="{DynamicResource MaterialDesignBodyLight}"
                            Grid.Column="1"
                            Kind="Monitor"
                            Margin="12,0,8,0"
                            VerticalAlignment="Center" />
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="桌面通知" />
                            <TextBlock
                                Foreground="{DynamicResource MaterialDesignBodyLight}"
                                Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                Text="检测到火灾时弹出桌面消息提示" />
                        </StackPanel>
                    </Grid>

                    <!--  邮件通知  -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ToggleButton
                            Grid.Column="0"
                            IsChecked="{Binding EnableEmail}"
                            Style="{StaticResource MaterialDesignSwitchToggleButton}"
                            VerticalAlignment="Center" />
                        <materialDesign:PackIcon
                            Foreground="{DynamicResource MaterialDesignBodyLight}"
                            Grid.Column="1"
                            Kind="Email"
                            Margin="12,0,8,0"
                            VerticalAlignment="Center" />
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="邮件通知" />
                            <TextBlock
                                Foreground="{DynamicResource MaterialDesignBodyLight}"
                                Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                Text="检测到火灾时向指定收件人发送邮件报警" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </materialDesign:Card>

            <!--  ===== Card 3：邮件配置（仅 EnableEmail=true 时显示） =====  -->
            <materialDesign:Card
                Margin="0,0,0,12"
                Padding="20"
                Visibility="{Binding IsEmailSectionVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <StackPanel Margin="0,0,0,16" Orientation="Horizontal">
                        <materialDesign:PackIcon
                            Foreground="{DynamicResource PrimaryHueMidBrush}"
                            Kind="EmailOutline"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center" />
                        <TextBlock
                            Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                            Text="邮件配置"
                            VerticalAlignment="Center" />
                    </StackPanel>

                    <!--  SMTP 配置（两列网格）  -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!--  SMTP 服务器  -->
                        <TextBox
                            Grid.Column="0"
                            Grid.Row="0"
                            Margin="0,0,0,12"
                            Style="{StaticResource MaterialDesignOutlinedTextBox}"
                            Text="{Binding SmtpServer, UpdateSourceTrigger=PropertyChanged}"
                            materialDesign:HintAssist.Hint="SMTP 服务器" />

                        <!--  端口  -->
                        <TextBox
                            Grid.Column="2"
                            Grid.Row="0"
                            Margin="0,0,0,12"
                            Style="{StaticResource MaterialDesignOutlinedTextBox}"
                            Text="{Binding SmtpPort, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=True, NotifyOnValidationError=True}"
                            materialDesign:HintAssist.Hint="端口" />

                        <!--  账号  -->
                        <TextBox
                            Grid.Column="0"
                            Grid.Row="1"
                            Margin="0,0,0,12"
                            Style="{StaticResource MaterialDesignOutlinedTextBox}"
                            Text="{Binding SmtpUsername, UpdateSourceTrigger=PropertyChanged}"
                            materialDesign:HintAssist.Hint="发件账号" />

                        <!--  密码  -->
                        <PasswordBox
                            Grid.Column="2"
                            Grid.Row="1"
                            Margin="0,0,0,12"
                            Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                            materialDesign:HintAssist.Hint="发件密码"
                            materialDesign:PasswordBoxAssist.Password="{Binding SmtpPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <!--  发件地址  -->
                        <TextBox
                            Grid.Column="0"
                            Grid.Row="2"
                            Margin="0,0,0,12"
                            Style="{StaticResource MaterialDesignOutlinedTextBox}"
                            Text="{Binding FromAddress, UpdateSourceTrigger=PropertyChanged}"
                            materialDesign:HintAssist.Hint="发件人地址" />

                        <!--  发件人名称  -->
                        <TextBox
                            Grid.Column="2"
                            Grid.Row="2"
                            Margin="0,0,0,12"
                            Style="{StaticResource MaterialDesignOutlinedTextBox}"
                            Text="{Binding FromName, UpdateSourceTrigger=PropertyChanged}"
                            materialDesign:HintAssist.Hint="发件人名称" />

                        <!--  SSL 开关  -->
                        <StackPanel
                            Grid.Column="0"
                            Grid.Row="3"
                            Orientation="Horizontal">
                            <ToggleButton
                                IsChecked="{Binding SmtpUseSsl}"
                                Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                VerticalAlignment="Center" />
                            <TextBlock
                                Margin="12,0,0,0"
                                Text="启用 SSL/TLS 加密"
                                VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>

                    <!--  收件人列表  -->
                    <Separator Margin="0,0,0,12" />
                    <Grid Margin="0,0,0,8">
                        <TextBlock
                            Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                            Text="邮件收件人"
                            VerticalAlignment="Center" />
                        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                            <Button
                                Command="{Binding SelectAllRecipientsCommand}"
                                Margin="0,0,4,0"
                                Padding="8,4"
                                Style="{StaticResource MaterialDesignFlatButton}">
                                <TextBlock Text="全选" />
                            </Button>
                            <Button
                                Command="{Binding UnselectAllRecipientsCommand}"
                                Padding="8,4"
                                Style="{StaticResource MaterialDesignFlatButton}">
                                <TextBlock Text="取消全选" />
                            </Button>
                        </StackPanel>
                    </Grid>

                    <TextBlock
                        Foreground="{DynamicResource MaterialDesignBodyLight}"
                        Margin="0,0,0,8"
                        Style="{StaticResource MaterialDesignCaptionTextBlock}"
                        Text="勾选需要接收火灾报警邮件的用户（无邮箱的用户不可选）" />

                    <Border
                        BorderBrush="{DynamicResource MaterialDesignDivider}"
                        BorderThickness="1"
                        CornerRadius="4">
                        <ListView
                            Background="Transparent"
                            ItemsSource="{Binding EmailRecipients}"
                            MaxHeight="220"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                            SelectionMode="Single">
                            <ListView.ItemContainerStyle>
                                <Style BasedOn="{StaticResource MaterialDesignListBoxItem}" TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="12,8" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!--  勾选框  -->
                                        <CheckBox
                                            Grid.Column="0"
                                            IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                            IsEnabled="{Binding CanSelect}"
                                            Margin="0,0,12,0"
                                            VerticalAlignment="Center" />

                                        <!--  用户信息  -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock FontWeight="Medium" Text="{Binding DisplayName}" />
                                            <TextBlock Foreground="{DynamicResource MaterialDesignBodyLight}" Style="{StaticResource MaterialDesignCaptionTextBlock}">
                                                <Run Text="{Binding Email, TargetNullValue='（无邮箱，不可选）'}" />
                                            </TextBlock>
                                        </StackPanel>

                                        <!--  角色标签占位（右侧）  -->
                                        <TextBlock
                                            Foreground="{DynamicResource MaterialDesignBodyLight}"
                                            Grid.Column="2"
                                            Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                            Text="无邮箱"
                                            VerticalAlignment="Center"
                                            Visibility="{Binding HasNoEmail, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Border>
                </StackPanel>
            </materialDesign:Card>

            <!--  ===== 保存按钮行 =====  -->
            <StackPanel
                HorizontalAlignment="Right"
                Margin="0,4,0,16"
                Orientation="Horizontal">
                <!--  保存状态提示  -->
                <StackPanel
                    Margin="0,0,16,0"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Visibility="{Binding ShowSaveStatus, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <materialDesign:PackIcon Margin="0,0,4,0" VerticalAlignment="Center">
                        <materialDesign:PackIcon.Style>
                            <Style TargetType="materialDesign:PackIcon">
                                <!--  默认显示失败图标（初始 SaveSuccess=false）  -->
                                <Setter Property="Kind" Value="AlertCircle" />
                                <Setter Property="Foreground" Value="#F44336" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SaveSuccess}" Value="True">
                                        <Setter Property="Kind" Value="CheckCircle" />
                                        <Setter Property="Foreground" Value="#4CAF50" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </materialDesign:PackIcon.Style>
                    </materialDesign:PackIcon>
                    <TextBlock Text="{Binding SaveStatusMessage}" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SaveSuccess}" Value="True">
                                        <Setter Property="Foreground" Value="#4CAF50" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SaveSuccess}" Value="False">
                                        <Setter Property="Foreground" Value="#F44336" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <!--  保存按钮  -->
                <Button
                    Command="{Binding SaveSettingsCommand}"
                    IsEnabled="{Binding CanSave}"
                    Style="{StaticResource MaterialDesignRaisedButton}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon
                            Kind="ContentSave"
                            Margin="0,0,6,0"
                            VerticalAlignment="Center" />
                        <TextBlock Text="保存设置" />
                    </StackPanel>
                </Button>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
